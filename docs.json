{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Samurai AI",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Chat & Text",
            "pages": [
              "api/chat-completions",
              "api/streaming",
              "api/function-calling",
              "api/vision",
              "api/embeddings"
            ]
          },
          {
            "group": "Image Generation",
            "pages": [
              "api/images/overview",
              "api/images/dalle",
              "api/images/stable-diffusion",
              "api/images/flux"
            ]
          },
          {
            "group": "Video Generation",
            "pages": [
              "api/video/overview",
              "api/video/sora",
              "api/video/veo",
              "api/video/luma"
            ]
          },
          {
            "group": "Audio",
            "pages": [
              "api/audio/text-to-speech",
              "api/audio/speech-to-text"
            ]
          },
          {
            "group": "SDKs & Libraries",
            "pages": ["sdks/python", "sdks/nodejs", "sdks/rest"]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/models",
              "reference/pricing",
              "reference/rate-limits",
              "reference/errors"
            ]
          }
        ]
      },
      {
        "tab": "API Playground",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Chat",
            "pages": [
              "api-reference/endpoint/chat-completions",
              "api-reference/endpoint/list-models"
            ]
          },
          {
            "group": "Images",
            "pages": [
              "api-reference/endpoint/create-image"
            ]
          },
          {
            "group": "Audio",
            "pages": [
              "api-reference/endpoint/create-speech",
              "api-reference/endpoint/create-transcription"
            ]
          },
          {
            "group": "Embeddings",
            "pages": [
              "api-reference/endpoint/create-embedding"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Browse Models",
          "href": "https://www.samuraiapi.in/models",
          "icon": "microchip"
        },
        {
          "anchor": "Dashboard",
          "href": "https://www.samuraiapi.in/dashboard",
          "icon": "gauge"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/samurai-ai",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@samuraiapi.in"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://www.samuraiapi.in/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/samuraiapi_in",
      "github": "https://github.com/bankai-max-wow"
    }
  }
}
