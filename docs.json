{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Samurai AI",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#3730A3"
  },
  "favicon": "/favicon.svg",
  "css": "/custom.css",
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
