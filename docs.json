  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/SamuraiAI_hq",
      "discord": "https://discord.gg/7TsWbcK2j",
      "telegram": "https://t.me/SamuraiApi0g",
